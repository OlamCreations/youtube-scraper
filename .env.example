VPS_HOST=user@your-vps-ip
REMOTE_ROOT=/path/to/youtube-pipeline
LOCAL_ROOT=./data
LOG_DIR=./logs

# Pipeline API (optional, used by manage.ps1)
# PIPELINE_SERVICE_NAME=youtube-pipeline
# YOUTUBE_PIPELINE_API=http://127.0.0.1:3847
# YOUTUBE_PIPELINE_TOKEN=your-bearer-token

# Python binary (optional, defaults to python)
# PYTHON=python3
